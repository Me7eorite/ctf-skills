service ctf
{
    disable     = no
    socket_type = stream
    protocol    = tcp
    wait        = no
    user        = root
    type        = UNLISTED
    port        = {{SERVICE_PORT}}
    bind        = 0.0.0.0
    server      = /usr/sbin/chroot
    server_args = --userspec={{CTF_UID}}:{{CTF_GID}} /home/ctf ./{{BINARY_NAME}}
    banner_fail = /etc/banner_fail

    per_source  = 10
    rlimit_cpu  = 20
    # Enable only when compatible with the intended exploit.
    # rlimit_as = 1024M
}

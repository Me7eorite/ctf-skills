# Copy to `.env` and edit. Both files live at the project root.
#
# `.env` is auto-loaded by python-dotenv from
# `src/persistence/engine.py::_ensure_dotenv_loaded`. Values already set
# in the shell environment win — `export DATABASE_URL=...` is not
# overridden by this file.

# Runtime / dev database. Required for every `challenge-factory research`
# subcommand, the dashboard's research endpoints, and `alembic upgrade`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@192.168.6.150:5432/challenge_factory

# Test database. Only consumed by tests marked `@pytest.mark.postgres`.
# Use a separate database (typically `*_test`) so tests can drop/recreate
# state without touching the dev data.
# TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@192.168.6.150:5432/challenge_factory_test

# Optional Hermes overrides used by the shard pipeline only — the
# research worker ignores HERMES_TIMEOUT by design.
# HERMES_CMD=hermes chat -Q --yolo -q
# HERMES_TIMEOUT=1500

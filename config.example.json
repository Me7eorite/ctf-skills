{
  "event": {
    "name": "Synthetic Training CTF",
    "flag_format": "flag{...}",
    "categories": ["web", "pwn", "re"]
  },
  "paths": {
    "work_dir": "work",
    "challenge_dir": "work/challenges",
    "report_dir": "work/reports",
    "log_dir": "work/logs"
  },
  "generation": {
    "max_retries": 3,
    "default_shard_size": 5,
    "profile": "generation-profiles.json",
    "category_shard_sizes": {
      "web": 10,
      "pwn": 5,
      "re": 10
    }
  },
  "hermes": {
    "command_env": "HERMES_CMD",
    "default_command": "hermes chat -Q --yolo -q"
  },
  "validation": {
    "require_real_exploit": true,
    "require_web_container": true,
    "require_pwn_elf": true,
    "require_reverse_binary": true
  }
}

{
  "version": 1,
  "categories": {
    "web": {
      "required_artifact": "single-service Docker image",
      "runtime_rotation": [
        {"runtime": "python", "frameworks": ["Flask", "FastAPI", "Django"]},
        {"runtime": "node", "frameworks": ["Express", "Fastify", "Koa"]},
        {"runtime": "php", "frameworks": ["plain PHP", "Slim", "Laravel"]},
        {"runtime": "java", "frameworks": ["Spring Boot", "Jakarta Servlet"]},
        {"runtime": "go", "frameworks": ["net/http", "Gin", "Fiber"]},
        {"runtime": "rust", "frameworks": ["Axum", "Actix Web", "Rocket"]}
      ],
      "technique_quota": 1,
      "cooldown_window": 1,
      "policy": [
        "A shard should use at least two runtimes when it contains three or more Web challenges.",
        "Do not select Python when the matrix row names another runtime.",
        "Pin dependencies and expose a deterministic health endpoint.",
        "The exploit must reach the running service and obtain the flag; no offline fallback is allowed."
      ]
    },
    "pwn": {
      "required_artifact": "Linux ELF plus single-service Docker image",
      "language_toolchains": {
        "c": {"compilers": ["gcc", "clang"], "target_format": "elf"},
        "cpp": {"compilers": ["g++", "clang++"], "target_format": "elf"},
        "rust": {"compilers": ["rustc", "cargo build --release"], "target_format": "elf"},
        "go": {"compilers": ["go build"], "target_format": "elf"},
        "asm": {"compilers": ["nasm + ld", "gcc"], "target_format": "elf"}
      },
      "toolchains": ["gcc", "clang", "g++", "clang++", "rustc", "cargo build --release", "go build", "nasm + ld"],
      "architectures": ["x86_64"],
      "technique_quota": 1,
      "cooldown_window": 1,
      "policy": [
        "Record PIE, NX, RELRO, canary, and stripped status.",
        "Compile the distributed ELF during generation.",
        "The exploit must target the built ELF or running TCP service."
      ]
    },
    "re": {
      "required_artifact": "compiled player-facing binary in attachments/",
      "artifact_rotation": [
        {"format": "elf", "languages": ["c", "cpp", "rust", "go"]},
        {"format": "wasm", "languages": ["c", "rust"]},
        {"format": "jar", "languages": ["java", "kotlin"]}
      ],
      "default_format": "elf",
      "default_platform": "linux/amd64",
      "language_toolchains": {
        "c": {"compiler": "gcc", "target_format": "elf"},
        "cpp": {"compiler": "g++", "target_format": "elf"},
        "rust": {"compiler": "rustc", "target_format": "elf"},
        "go": {"compiler": "go build", "target_format": "elf"},
        "java": {"compiler": "javac", "target_format": "jar"},
        "kotlin": {"compiler": "kotlinc", "target_format": "jar"}
      },
      "technique_quota": 1,
      "cooldown_window": 1,
      "policy": [
        "Unless the matrix explicitly requests another format, compile a Linux amd64 ELF.",
        "Source code alone or a README placeholder in attachments/ is not a deliverable.",
        "The solve script must derive the flag from the distributed artifact, not from source or metadata.",
        "Record compiler, flags, SHA-256, file format, and architecture."
      ]
    }
  }
}
